{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Corpus Lille-Mele",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id",
      "number",
      "title",
      "intro",
      "finalNote",
      "status",
      "tags",
      "sourceIds",
      "bonus",
      "groups"
    ],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "number": { "type": "integer", "minimum": 1 },
      "title": { "type": "string", "minLength": 1, "maxLength": 60 },
      "intro": { "type": "string", "minLength": 1, "maxLength": 140 },
      "finalNote": { "type": "string", "minLength": 1, "maxLength": 320 },
      "status": {
        "type": "string",
        "enum": ["prototype", "reviewed", "published"]
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "sourceIds": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "bonus": {
        "type": "object",
        "required": ["question", "answer", "explanation"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string", "minLength": 1, "maxLength": 140 },
          "answer": { "type": "boolean" },
          "explanation": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      },
      "groups": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "object",
          "required": ["id", "title", "difficulty", "sourceIds", "items", "note"],
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "title": { "type": "string", "minLength": 1, "maxLength": 60 },
            "difficulty": {
              "type": "string",
              "enum": ["easy", "medium", "hard", "tricky"]
            },
            "sourceIds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              }
            },
            "tags": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              }
            },
            "items": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 40 }
            },
            "note": { "type": "string", "minLength": 1, "maxLength": 180 }
          }
        }
      }
    }
  }
}
